<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
	<GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>
  <Target Name="PreBuild" BeforeTargets="PreBuildEvent">
    <Exec Command="git show --pretty=medium --no-patch &gt; &quot;$(ProjectDir)version.txt&quot;&#xD;&#xA;npm run build" />
  </Target>
  <Target Name="PostBuild" AfterTargets="PostBuildEvent">
    <Exec Command="xcopy &quot;$(ProjectDir)version.txt&quot; &quot;$(SolutionDir)DungeonCrawler2.Electron\&quot; /d /Y&#xD;&#xA;xcopy &quot;$(ProjectDir)dist&quot; &quot;$(SolutionDir)DungeonCrawler2.Electron\src\&quot; /s /d /Y" />
  </Target>
  <ItemGroup>
    <None Remove="dist\bundle.js" />
    <None Remove="version.txt" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="version.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <Content Include="dist\bundle.js">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
</Project>